{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "no-contact-days.vercel.app"
        }
      ],
      "destination": "https://www.thenocontacttracker.com/:path*",
      "permanent": true
    },
    {
      "source": "/no-contact-rule/:path*",
      "destination": "/no-contact-rule-after-breakup/",
      "permanent": true
    },
    {
      "source": "/i-want-to-text-my-ex/:path*",
      "destination": "/want-to-text-your-ex/",
      "permanent": true
    },
    {
      "source": "/texts-to-send-your-ex/:path*",
      "destination": "/what-to-text-an-ex/",
      "permanent": true
    },
    {
      "source": "/how-long-should-no-contact-last/:path*",
      "destination": "/how-long-should-i-do-no-contact/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/sitemap-index.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
